# Per-package ignores live in each package's own .gitignore.
# Repo-level ignores:

.DS_Store
*.log

# editor / local tooling
.vscode/
.idea/
*.swp

# Local Claude Code session state (per-developer)
.claude/

# Never commit a key file if one is dropped in-repo
*.key
xai.key

# Node (legacy-voice runs from here only)
node_modules/

# Rust + Trunk artifacts
/target/
**/target/
/dist/
crates/ocean-gui/canvas-web/dist/

# Tauri build output (added in Phase 4)
/crates/ocean-surface-app/gen/
/crates/ocean-surface-app/target/

# local UI test artifacts
.playwright-mcp/
tool-group-collapsed.png
extension/dist/
