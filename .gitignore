# Node (legacy-voice runs from here only)
node_modules/

# Rust + Trunk artifacts
/target/
**/target/
/dist/

# Tauri build output (added in Phase 4)
/crates/ocean-surface-app/gen/
/crates/ocean-surface-app/target/
