# ocean-voice configuration — copy to .env and fill in. NEVER commit a real .env.
# ocean-voice holds no provider credentials; the Ocean runtime owns those.

# --- Ocean runtime (the brain) ---
OCEAN_DAEMON_URL=http://127.0.0.1:4780
# Working directory the agent operates in for voice turns.
OCEAN_VOICE_CWD=/home/you
# Optional: abort a turn after this many ms.
OCEAN_PROMPT_TIMEOUT_MS=300000

# --- Desktop voice daemon (src/daemon.mjs) ---
OCEAN_VOICE_HOST=127.0.0.1
OCEAN_VOICE_PORT=8787
# Runtime state (sessions, cached status audio). Defaults to ~/.ocean-voice.
# OCEAN_VOICE_STATE_DIR=/home/you/.ocean-voice

# --- Web/PWA connector (src/web-server.mjs) ---
VOICE_WEB_HOST=127.0.0.1
VOICE_WEB_PORT=8790
# REQUIRED before binding beyond localhost (LAN / Tailscale). Use a long random value.
VOICE_WEB_TOKEN=
# Optional HTTP Basic auth instead of / in addition to the token.
VOICE_WEB_USER=
VOICE_WEB_PASSWORD=

# --- Speech (xAI Grok STT/TTS) ---
# Used by the web connector (browser mic STT + TTS) AND the desktop daemon's TTS.
# xAI is the only TTS engine; if it is unavailable the voice stays silent.
XAI_API_KEY=
XAI_STT_MODEL=grok-stt
# Desktop TTS voice (default: leo) and playback speed.
# OCEAN_VOICE_PLAYBACK_SPEED=1.3
